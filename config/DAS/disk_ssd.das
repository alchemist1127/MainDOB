# Doppio click: DobDisk preselezionato su questo disco (partizioni,
# proprieta', SMART). Spawn via dobinterface (open_program), il
# percorso launcher-proven.
action {
    open_program  /SYSTEM/PROGRAMS/DobDisk/DobDisk.mdl --select sata_$token   on_fail dobdisk_failed
}

menu {
    item "Apri in DobDisk"
    {
        open_program  /SYSTEM/PROGRAMS/DobDisk/DobDisk.mdl --select sata_$token   on_fail dobdisk_failed
    }
    item "Informazioni"
    {
        popup_info  "Disco SSD"  "Provider: $provider, token $token"
    }
}

errors {
    dobdisk_failed = popup_error "Disco SSD" "Impossibile avviare DobDisk."
}

category = storage
