.........#..........................#...........
..........##......................##............
............##..................##..............
...............##################...............
................................................
................................................
................................................
}

action {
    spawn         /SYSTEM/DRIVERS/cdrom/cdrom.mdl  ahci:$token  on_fail hw_fault
    wait_service  cdrom_ahci_$token  timeout=3000               on_fail hw_fault
    ipc_call      cdrom_ahci_$token  64                         on_fail probe_error
}

menu {
    item "Espelli"
    {
        wait_service  cdrom_ahci_$token  timeout=1000           on_fail hw_fault
        ipc_call      cdrom_ahci_$token  65                     on_fail hw_fault
        popup_info    "Disco ottico" "Disco espulso."
    }
}

errors {
    probe_error  = popup_error "Disco ottico" "Impossibile leggere il disco. Verifica che il CD sia inserito e non danneggiato."
    hw_fault     = popup_error "Disco ottico" "Il driver CD-ROM non risponde."
}

category = removable
