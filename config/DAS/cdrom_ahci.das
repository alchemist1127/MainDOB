# Optical disc on AHCI — matched by class:subclass on any sub-device the
# ahci driver announces. Dynamic: the icon appears at boot (or at insert
# once GESN async-notification is wired) and disappears on eject via
# HOTPLUG_SUBDEVICE_GONE. The icon represents the disc, not the drive.

bus_type = subdevice
class    = 0x01
subclass = 0x05

label   = Disco ottico
kind    = storage
driver  = /SYSTEM/DRIVERS/cdrom/cdrom.mdl
service = cdrom

bitmap_w    = 48
bitmap_h    = 48
bitmap_fg_r = 192
bitmap_fg_g = 192
bitmap_fg_b = 192

bitmap {
................................................
................................................
................................................
