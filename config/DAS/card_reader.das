}

# Double-click: identico alla pendrive (spawn usbms -> PREPARE_VOLUME ->
# mount -> finestra), ma con i messaggi del lettore.
action {
    spawn         /SYSTEM/DRIVERS/usb_mass_storage/usb_mass_storage.mdl $provider:$token   on_fail usbms_failed
    wait_service  usbms_$token  timeout=8000                                               on_fail usbms_failed
    ipc_call      usbms_$token  66                                                         on_fail novolume
    wait_service  dobfs_$token  timeout=8000                                               on_fail mount_failed
    ipc_call      dobfs_$token  21                                                         on_fail mount_failed
}

menu {
    item "Formatta..."
    {
        spawn         /SYSTEM/DRIVERS/usb_mass_storage/usb_mass_storage.mdl $provider:$token   on_fail usbms_failed
        wait_service  usbms_$token  timeout=8000                                               on_fail usbms_failed
        ipc_call      usbms_$token  67                                                         on_fail bringup_failed
        open_program  /SYSTEM/PROGRAMS/DobDisk/DobDisk.mdl --select usbms_$token               on_fail fmt_failed
    }
    item "Informazioni"
    {
        popup_info  "Lettore schede SD"  "Provider: $provider, porta $token"
    }
}

errors {
    usbms_failed = popup_error "Lettore schede SD" "Impossibile avviare il driver mass-storage. Apri usbdiag per la diagnostica."
    # Caso NORMALE del lettore: slot vuoto (DOB_ERR_NO_MEDIA = -9).
    novolume_9   = popup_info  "Lettore schede SD" "Nessuna scheda inserita nel lettore. Inserisci una scheda e riprova."
    novolume     = popup_error "Lettore schede SD" "Scheda presente ma nessun volume FAT32/exFAT leggibile (DobDisk per formattare)."
    mount_failed = popup_error "Lettore schede SD" "Volume trovato ma montaggio fallito. Apri usbdiag (fase 4)."
    fmt_failed     = popup_error "Lettore schede SD" "Impossibile avviare DobDisk."
    bringup_failed = popup_error "Lettore schede SD" "Inizializzazione del lettore fallita. Apri usbdiag (fase 4)."
    bringup_failed_9 = popup_info "Lettore schede SD" "Nessuna scheda inserita nel lettore. Inserisci una scheda e riprova."
}

category = storage
