# MainDOB Device Automation Script — internal USB SD card reader.
#
# Subdevice DAS for class 0x01:0x07 (storage / card reader), announced
# by the USB host-controller drivers when a USB-level DAS refined the
# match by vendor id (see config/DAS/USB/card_reader_icsi.das). Same
# pipeline as the pendrive (usb_mass_storage.das), same sub-driver
# (usb_mass_storage.mdl) — different identity on the desktop:
#   - dedicated microSD icon (reference artwork provided in the field);
#   - reader-appropriate wording: an EMPTY SLOT is this device's normal
#     state, so the no-media outcome is an informational popup, never
#     the red "no FAT32, format it!" a pendrive gets;
#   - the DobDisk hand-off uses open_program (spawn via dobinterface,
#     the launcher-proven path) like the pendrive's Formatta.

bus_type = subdevice
class    = 0x01
subclass = 0x07

label = Lettore schede SD
kind  = storage

bitmap_w    = 48
bitmap_h    = 48
bitmap_fg_r = 150
bitmap_fg_g = 180
bitmap_fg_b = 220

# microSD: corpo con tacca sul lato destro, 3 contatti in alto,
# etichetta rettangolare in basso (dal riferimento fornito).
bitmap {
